{
  "name": "cerase-acp",
  "version": "0.2.0-dev",
  "description": "In-house Discord-to-ACP bridge for Cerase. DM-only, one long-lived ACP session per (user, agent), colleague-style UX.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.22.1",
    "discord.js": "^14.26.0",
    "pino": "^10.3.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "pino-pretty": "^13.1.0",
    "tsx": "^4.22.0",
    "typescript": "~5.9.0",
    "vitest": "^4.1.0"
  }
}
